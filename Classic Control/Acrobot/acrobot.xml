<mujoco model="acrobot">
    <option timestep="0.002" gravity="0 0 -9.81"/>
    
    <visual>
        <headlight ambient=".4 .4 .4" diffuse=".8 .8 .8" specular="0.1 0.1 0.1"/>
        <map znear="0.01"/>
    </visual>

    <asset>
        <texture name="grid" type="2d" builtin="checker" rgb1=".1 .2 .3" rgb2=".2 .3 .4" width="300" height="300" mark="edge" markrgb=".2 .3 .4"/>
        <material name="grid" texture="grid" texrepeat="2 2" texuniform="true"/>
    </asset>

    <worldbody>
        <geom name="floor" type="plane" size="5 5 0.1" material="grid"/>
        <light pos="0 0 3" dir="0 0 -1" diffuse="1 1 1"/>
        
        <body name="base" pos="0 0 2.5">
            <geom type="sphere" size="0.05" rgba=".1 .1 .1 1"/>
            <body name="link1" pos="0 0 0">
                <joint name="joint1" type="hinge" axis="0 1 0" pos="0 0 0" damping="0.1"/>
                <geom name="l1" type="capsule" fromto="0 0 0 0 0 -1" size="0.04" rgba="1 0 0 1"/>
                <body name="link2" pos="0 0 -1">
                    <joint name="joint2" type="hinge" axis="0 1 0" pos="0 0 0" damping="0.1"/>
                    <geom name="l2" type="capsule" fromto="0 0 0 0 0 -1" size="0.04" rgba="0 0 1 1"/>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <motor joint="joint2" ctrlrange="-10 10" ctrllimited="true"/>
    </actuator>
</mujoco>
